# Dependencies
node_modules/

# SQLite runtime state — dial.db itself is a committed pre-seeded snapshot
# (delete it to fall back to code-seeding on boot); only the transient
# WAL/journal sidecars are ignored.
dial.db-journal
dial.db-shm
dial.db-wal

# OS / editor junk
.DS_Store

# Backups & logs
*.bak
*.log

# Secrets — never commit private keys / RPC creds (EVM mirror deploy)
.env
.env.local
.env.*.local
