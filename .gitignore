# Dependencies
node_modules/

# SQLite runtime state — the app seeds demo data from code on first boot
# (seedIfEmpty), or syncs from Turso when configured. The local dial.db and its
# WAL/journal sidecars are gitignored.
dial.db
dial.db-journal
dial.db-shm
dial.db-wal

# OS / editor junk
.DS_Store

# Backups & logs
*.bak
*.log

# Secrets — never commit private keys / RPC creds (EVM mirror deploy)
.env
.env.local
.env.*.local
