# Copy to .env and fill in. .env is gitignored — never commit a real private key.
# The app runs fine WITHOUT any of this (set DIAL_EVM_ENABLED=false) — the EVM
# mirror just stays mocked. Set these to anchor records on a real chain.

# ── EVM mirror (DialRegistry + DialName on Sepolia / a local anvil) ──
DIAL_EVM_ENABLED=true
# DIAL_EVM_SELF_CUSTODY=true                    # default true: DIAL sends NO tx — the consumer's wallet
                                                #   writes the chain (claim/setAddresses/mint) + pays gas.
                                                #   Set false to restore the owner-relayer mirror (DIAL pays).
DIAL_EVM_NETWORK=sepolia                       # sepolia | mainnet | anvil (label: explorer + display)
DIAL_EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
DEPLOYER_PRIVATE_KEY=0xYourFundedRelayerKey     # deploys + relays mirror txs; also the contract owner/minter
DIAL_REGISTRY_ADDRESS=0xYourDeployedDialRegistry
DIAL_NAME_NFT_ADDRESS=0xYourDeployedDialName     # ERC-721 names-as-NFTs (optional; enables minting)

# ── SIWE wallet-link (signature verification only — chain-agnostic) ──
# WALLET_NETWORK=sepolia                        # sets the SIWE message chainId (default sepolia)
# ETH_RPC_URL=https://...                       # only used for EIP-1271 smart-contract-wallet sigs

# ── Misc ──
# SESSION_SECRET=change-me                      # HMAC secret for session tokens (REQUIRED in production)
# DIAL_SIGNING_SECRET=change-me                 # Canton/mirror HMAC stand-in
# PORT=3000
