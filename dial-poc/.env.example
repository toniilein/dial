# EVM mirror (DialRegistry on Sepolia/anvil). Copy to .env and fill in.
# .env is gitignored — never commit a real private key.
DIAL_EVM_ENABLED=true
DIAL_EVM_NETWORK=sepolia                 # sepolia | mainnet | anvil
DIAL_EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
DIAL_REGISTRY_ADDRESS=0xYourDeployedDialRegistry
DEPLOYER_PRIVATE_KEY=0xYourFundedRelayerKey   # deploys + sends mirror txs; also the contract owner
