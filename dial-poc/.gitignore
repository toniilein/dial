node_modules/
# dial.db is a local runtime file — the app seeds demo data from code on first
# boot (seedIfEmpty), so it and its transient sidecars are gitignored.
dial.db
dial.db-journal
dial.db-shm
dial.db-wal

# Turso embedded replicas (shared-DB mode) — materialized from the remote primary
dial-replica.db*
merge-replica.db*
*.log
.DS_Store

# Secrets — never commit private keys / RPC creds (EVM mirror deploy)
.env
.env.local
.env.*.local

# Solidity build artifacts (bytecode is regenerated from the .sol; ABIs are committed)
contracts/*.bytecode.json
forge-out/
forge-cache/
